{
  "name": "opticonnectgis-backend",
  "version": "1.0.0",
  "description": "Backend API server for PersonalGIS Platform with PostgreSQL database",
  "main": "server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --max-old-space-size=8192 server.js",
    "start": "cross-env NODE_ENV=production node --max-old-space-size=8192 server.js",
    "start:win": "cross-env NODE_ENV=production node --max-old-space-size=8192 server.js",
    "dev:win": "cross-env NODE_ENV=development nodemon --max-old-space-size=8192 server.js",
    "switch:dev": "node scripts/switch-env.js development",
    "switch:prod": "node scripts/switch-env.js production",
    "test": "node test-apis.js",
    "test-apis": "node test-apis.js",
    "verify-schema": "node scripts/verify-db-schema.js",
    "check-db": "node scripts/verify-db-schema.js"
  },
  "keywords": [
    "gis",
    "telecom",
    "infrastructure",
    "maps",
    "api"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "@mapbox/togeojson": "^0.16.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xmldom/xmldom": "^0.9.9",
    "adm-zip": "^0.5.16",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fast-xml-parser": "^5.5.9",
    "helmet": "^7.1.0",
    "jimp": "^0.16.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.9",
    "pg": "^8.16.3",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.8.0"
  }
}
